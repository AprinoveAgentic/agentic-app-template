# ── Local development environment ─────────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database (Docker Compose default — change for external DB)
DATABASE_URL=postgresql://appuser:localpassword@localhost:5432/appdb

# JWT — generate strong random secrets (min 32 chars)
# Example: openssl rand -base64 48
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars_long
JWT_REFRESH_SECRET=change_me_to_another_random_string_at_least_32_chars

# CORS — web frontend origin
CORS_ORIGIN=http://localhost:3000

# Registration allowlist — comma-separated domains, empty = open registration
# Example: ALLOWED_EMAIL_DOMAINS=yourcompany.com,contractor.com
ALLOWED_EMAIL_DOMAINS=

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
